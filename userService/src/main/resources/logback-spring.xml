<configuration>

    <!-- Console appender in JSON -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder" />
    </appender>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE" />
    </root>

    <!-- Logger della tua app -->
    <logger name="com.Zeta.demo_Zeta" level="DEBUG" additivity="true">
        <appender-ref ref="JSON_CONSOLE" />
    </logger>

</configuration>